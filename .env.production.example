# ── Strapi Production Environment ─────────────────────────────────────────────
# Copy to .env on your server / paste into Railway / Render env var panel.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"

HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# ── Secrets (generate fresh values — never reuse dev values) ──────────────────
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

# ── Database (Railway / Render auto-sets DATABASE_URL) ────────────────────────
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSL=true

# ── CORS: comma-separated list of allowed origins ─────────────────────────────
# Add your Vercel production URL and any preview domains you want to allow.
CORS_ORIGINS=https://terasu.vercel.app,https://terasu.com
